# Copie para `.env` e ajuste. `.env` é ignorado pelo git (segredos fora do código).

# --- Banco de DEV = Postgres do Supabase local (ADR-006). Rode `pnpm exec supabase start`. ---
# Portas remapeadas p/ 544xx (faixa 543xx cai num excluded port range do Windows; ver config.toml).
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54422/postgres

# Banco de TESTES rápidos (Postgres leve do docker-compose; sem schema auth). `docker compose up -d db`.
TEST_DATABASE_URL=postgres://postgres:postgres@127.0.0.1:5433/igni_test

# --- Supabase local (pegue os valores na saída de `supabase start` / `supabase status`) ---
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54421
NEXT_PUBLIC_SUPABASE_ANON_KEY=<publishable key local>
SUPABASE_SERVICE_ROLE_KEY=<secret key local — NUNCA commitar a real>

# --- Quiosque de setor (P-0): segredo do HMAC do PIN de 4 dígitos ---
# Mata a rainbow table de PIN de baixa entropia num eventual dump do banco (o PIN é carimbo, não
# credencial). Se ausente, cai no service_role e depois num default de dev. Em prod, DEFINA um valor
# aleatório longo nos secrets do Railway e NUNCA o rotacione sem re-emitir os PINs.
PIN_HMAC_SECRET=<segredo aleatório longo — defina em prod>

# --- Segurança: lockout de login (RNF-SEC-05, configurável) ---
AUTH_MAX_LOGIN_ATTEMPTS=5
